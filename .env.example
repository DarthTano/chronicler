# Copy this file to ".env" and fill in your real values.
# The .env file is gitignored and will NEVER be committed.

# Supabase (added in Phase 1 — leave blank for now)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Anthropic API key — powers the AI homebrew generator (Campaigns page).
# SERVER-SIDE ONLY: read by /api/generate (Vercel function) and the Vite dev
# shim. NOT VITE_-prefixed, so it is never exposed to the browser. Get one at
# https://console.anthropic.com/settings/keys . In production, set this in
# Vercel → Project → Settings → Environment Variables (NOT in this file).
ANTHROPIC_API_KEY=
